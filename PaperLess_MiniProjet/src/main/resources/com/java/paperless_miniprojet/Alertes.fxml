<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane
        hgap="15"
        vgap="15"
        prefWidth="800.0"
        prefHeight="600.0"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.java.paperless_miniprojet.controller.AlertesController">

    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

    <columnConstraints>
        <ColumnConstraints prefWidth="200"/>
        <ColumnConstraints prefWidth="200"/>
        <ColumnConstraints prefWidth="200"/>
        <ColumnConstraints prefWidth="130"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="45"/>
        <RowConstraints minHeight="35"/>
        <RowConstraints minHeight="400"/>
        <RowConstraints minHeight="45"/>
    </rowConstraints>

    <Label text="PaperLess - Alertes"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="0"/>
    <Button text="Retour Dashboard"
            onAction="#goToDashboard"
            GridPane.columnIndex="3"
            GridPane.rowIndex="0"/>

    <Label text="Départements ayant dépassé ou approché leur objectif :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="1"
           GridPane.columnSpan="4"/>

    <TableView fx:id="tableAlertes"
               prefHeight="380"
               prefWidth="720"
               GridPane.columnIndex="0"
               GridPane.rowIndex="2"
               GridPane.columnSpan="4">
        <columns>
            <TableColumn fx:id="colDept"     text="Département" prefWidth="160"/>
            <TableColumn fx:id="colConsomme" text="Consommé"    prefWidth="130"/>
            <TableColumn fx:id="colObjectif" text="Objectif"    prefWidth="130"/>
            <TableColumn fx:id="colEcart"    text="Écart"       prefWidth="110"/>
            <TableColumn fx:id="colStatut"   text="Statut"      prefWidth="150"/>
        </columns>
    </TableView>

    <Button text="Actualiser"
            onAction="#handleActualiser"
            GridPane.columnIndex="0"
            GridPane.rowIndex="3"/>

</GridPane>