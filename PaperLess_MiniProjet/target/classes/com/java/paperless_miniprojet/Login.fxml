<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane
        alignment="CENTER"
        hgap="10"
        vgap="15"
        prefWidth="500.0"
        prefHeight="400.0"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.java.paperless_miniprojet.controller.LoginController">

    <padding><Insets top="80" right="80" bottom="80" left="80"/></padding>

    <columnConstraints>
        <ColumnConstraints prefWidth="130"/>
        <ColumnConstraints prefWidth="230"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="30"/>
        <RowConstraints minHeight="40"/>
    </rowConstraints>

    <Label text="PaperLess - Connexion"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="0"/>

    <Label text="Email :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="1"/>
    <TextField fx:id="emailField"
               promptText="Entrez votre email"
               GridPane.columnIndex="1"
               GridPane.rowIndex="1"/>

    <Label text="Mot de passe :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="2"/>
    <PasswordField fx:id="passwordField"
                   promptText="Entrez votre mot de passe"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="2"/>

    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: red; -fx-font-size: 12px;"
           GridPane.columnIndex="1"
           GridPane.rowIndex="3"/>

    <Button text="Se connecter"
            onAction="#handleLogin"
            prefWidth="150"
            GridPane.columnIndex="1"
            GridPane.rowIndex="4"/>

</GridPane>