<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane
        hgap="15"
        vgap="12"
        prefWidth="800.0"
        prefHeight="600.0"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.java.paperless_miniprojet.controller.DashboardController">

    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

    <columnConstraints>
        <ColumnConstraints prefWidth="180"/>
        <ColumnConstraints prefWidth="180"/>
        <ColumnConstraints prefWidth="180"/>
        <ColumnConstraints prefWidth="180"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="45"/>
        <RowConstraints minHeight="45"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="30"/>
        <RowConstraints minHeight="280"/>
    </rowConstraints>

    <Label text="PaperLess - Tableau de bord"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="0"/>
    <Button text="Déconnexion"
            onAction="#handleLogout"
            style="-fx-text-fill: red;"
            GridPane.columnIndex="3"
            GridPane.rowIndex="0"/>

    <Button text="Consommation"
            onAction="#goToConsommation"
            prefWidth="160"
            GridPane.columnIndex="0"
            GridPane.rowIndex="1"/>
    <Button text="Alertes"
            onAction="#goToAlertes"
            prefWidth="160"
            GridPane.columnIndex="1"
            GridPane.rowIndex="1"/>

    <Label text="Total ce mois (rames) :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="2"/>
    <Label fx:id="kpiTotal"
           text="0"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"
           GridPane.columnIndex="1"
           GridPane.rowIndex="2"/>

    <Label text="Objectif global :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="3"/>
    <Label fx:id="kpiObjectif"
           text="0"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"
           GridPane.columnIndex="1"
           GridPane.rowIndex="3"/>

    <Label text="Alertes actives :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="4"/>
    <Label fx:id="kpiAlertes"
           text="0"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: red;"
           GridPane.columnIndex="1"
           GridPane.rowIndex="4"/>

    <Label text="Consommation par département :"
           style="-fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="5"/>

    <BarChart fx:id="barChart"
              prefHeight="260"
              prefWidth="720"
              GridPane.columnIndex="0"
              GridPane.rowIndex="6"
              GridPane.columnSpan="4">
        <xAxis><CategoryAxis label="Département"/></xAxis>
        <yAxis><NumberAxis label="Rames"/></yAxis>
    </BarChart>

</GridPane>