<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane
        hgap="12"
        vgap="12"
        prefWidth="800.0"
        prefHeight="600.0"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.java.paperless_miniprojet.controller.ConsommationController">

    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

    <columnConstraints>
        <ColumnConstraints prefWidth="160"/>
        <ColumnConstraints prefWidth="180"/>
        <ColumnConstraints prefWidth="160"/>
        <ColumnConstraints prefWidth="180"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="45"/>
        <RowConstraints minHeight="30"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="40"/>
        <RowConstraints minHeight="30"/>
        <RowConstraints minHeight="30"/>
        <RowConstraints minHeight="300"/>
        <RowConstraints minHeight="45"/>
    </rowConstraints>

    <Label text="PaperLess - Consommation"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="0"/>
    <Button text="Retour Dashboard"
            onAction="#goToDashboard"
            GridPane.columnIndex="3"
            GridPane.rowIndex="0"/>

    <Label text="Ajouter une consommation :"
           style="-fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="1"/>

    <Label text="Département :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="2"/>
    <ComboBox fx:id="deptCombo"
              promptText="Choisir..."
              prefWidth="180"
              GridPane.columnIndex="1"
              GridPane.rowIndex="2"/>
    <Label text="Quantité (rames) :"
           GridPane.columnIndex="2"
           GridPane.rowIndex="2"/>
    <TextField fx:id="quantiteField"
               promptText="Ex: 100"
               GridPane.columnIndex="3"
               GridPane.rowIndex="2"/>

    <Label text="Date :"
           GridPane.columnIndex="0"
           GridPane.rowIndex="3"/>
    <DatePicker fx:id="datePicker"
                prefWidth="180"
                GridPane.columnIndex="1"
                GridPane.rowIndex="3"/>
    <Button text="Ajouter"
            onAction="#handleAjouter"
            GridPane.columnIndex="3"
            GridPane.rowIndex="3"/>

    <Label fx:id="messageLabel"
           text=""
           GridPane.columnIndex="0"
           GridPane.rowIndex="4"
           GridPane.columnSpan="4"/>

    <Label text="Liste des consommations :"
           style="-fx-font-weight: bold;"
           GridPane.columnIndex="0"
           GridPane.rowIndex="5"/>

    <TableView fx:id="tableConsommation"
               prefHeight="280"
               prefWidth="720"
               GridPane.columnIndex="0"
               GridPane.rowIndex="6"
               GridPane.columnSpan="4">
        <columns>
            <TableColumn fx:id="colId"       text="ID"          prefWidth="60"/>
            <TableColumn fx:id="colDept"     text="Département" prefWidth="200"/>
            <TableColumn fx:id="colQuantite" text="Quantité"    prefWidth="150"/>
            <TableColumn fx:id="colDate"     text="Date"        prefWidth="180"/>
        </columns>
    </TableView>

    <Button text="Modifier"
            onAction="#handleModifier"
            GridPane.columnIndex="0"
            GridPane.rowIndex="7"/>
    <Button text="Supprimer"
            onAction="#handleSupprimer"
            style="-fx-text-fill: red;"
            GridPane.columnIndex="1"
            GridPane.rowIndex="7"/>
    <Button text="Actualiser"
            onAction="#handleActualiser"
            GridPane.columnIndex="2"
            GridPane.rowIndex="7"/>

</GridPane>